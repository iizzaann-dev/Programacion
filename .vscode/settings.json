{
  "filewatcher.commands": [
    {
      "match": "\\.java$",
      "cmd": "bash .devcontainer/generate-java.sh ${file}"
    },
    {
      "match": "JavaDocs/[^/]+$",
      "cmd": "bash .devcontainer/init-projects.sh"
    }
  ],
  "java.project.openProjectInNewWindow": false,
  "window.openFoldersInNewWindow": "off"
}