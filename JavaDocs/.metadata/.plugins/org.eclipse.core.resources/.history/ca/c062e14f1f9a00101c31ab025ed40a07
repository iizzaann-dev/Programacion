package OperadoresBasicos;

public class EjOperadoresBasicos {

	public static void main(String[] args) {
		int dato1,dato2;
		
		dato1 = 5;
		dato2= 4;
		
		int suma;
		suma = dato1+dato2;
		System.out.println("La suma es: " + suma);
		
		int resta;
		resta = dato1 - dato2;
		System.out.println("La resta es: " + resta);
		
		int multiplicacion;
		multiplicacion = dato1*dato2;
		System.out.println("La multiplicación es: " + multiplicacion);
		
		float division;
		division = dato1/dato2;
		System.out.println("La división es: " + division.float);
		
		int resto;
		resto = dato1%dato2;
		System.out.println("El resto de la división es: " + resto);
		

	}

}
